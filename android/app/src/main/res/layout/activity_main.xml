<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    tools:context=".activity.MainActivity">

    <!-- ── Hero Banner ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutHero"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header_hero"
        android:paddingTop="@dimen/spacing_24"
        android:paddingBottom="@dimen/spacing_32"
        android:paddingHorizontal="@dimen/spacing_16"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Greeting row: text left, avatar right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/greeting_label"
                    android:textColor="@color/text_on_primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter"
                    android:alpha="0.85" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/greeting_fallback"
                    android:textColor="@color/text_on_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter"
                    android:layout_marginTop="@dimen/spacing_2"
                    tools:text="Long Travis" />

            </LinearLayout>

            <!-- Avatar button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="@dimen/spacing_12"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="@dimen/radius_pill"
                app:cardBackgroundColor="@color/background_primary"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:rippleColor="@color/primary_light">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    app:tint="@color/primary_text"
                    android:contentDescription="@string/cd_nav_profile" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_subtitle"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp"
            android:fontFamily="@font/inter"
            android:alpha="0.7"
            android:layout_marginTop="@dimen/spacing_8" />

    </LinearLayout>

    <!-- ── Search & Filter ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="@dimen/spacing_16"
        android:layout_marginEnd="@dimen/spacing_16"
        android:layout_marginTop="@dimen/spacing_16"
        app:layout_constraintTop_toBottomOf="@id/layoutHero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_12"
            app:boxCornerRadiusBottomEnd="@dimen/radius_pill"
            app:boxCornerRadiusBottomStart="@dimen/radius_pill"
            app:boxCornerRadiusTopEnd="@dimen/radius_pill"
            app:boxCornerRadiusTopStart="@dimen/radius_pill"
            app:boxStrokeColor="@color/edittext_stroke_color"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/primary"
            app:startIconDrawable="@drawable/ic_search">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/search_hint"
                android:inputType="text"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:textColor="@color/text_heading"
                android:paddingHorizontal="@dimen/spacing_20" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnFilter"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="@dimen/radius_pill"
            app:cardBackgroundColor="@color/primary"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/text_on_primary"
                android:contentDescription="@string/cd_filter" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- ── Section Title ───────────────────────────────────── -->
    <TextView
        android:id="@+id/tvSectionFields"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/section_featured_fields"
        android:textColor="@color/text_heading"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/inter"
        android:layout_marginStart="@dimen/spacing_16"
        android:layout_marginEnd="@dimen/spacing_16"
        android:layout_marginTop="@dimen/spacing_24"
        app:layout_constraintTop_toBottomOf="@id/layoutSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Field List ──────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFields"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_12"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_16"
        android:paddingBottom="@dimen/spacing_64"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSectionFields"
        app:layout_constraintVertical_bias="0.0" />

    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
