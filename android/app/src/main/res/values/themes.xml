<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TimSanBong" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryVariant">@color/brand_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_light</item>
        <item name="colorOnSecondary">@color/text_title</item>
        <item name="android:statusBarColor">@color/brand</item>
    </style>

    <style name="Theme.TimSanBong.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand</item>
        <item name="colorPrimaryVariant">@color/brand_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_light</item>
        <item name="colorOnSecondary">@color/text_title</item>
        <item name="android:statusBarColor">@color/brand</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- BottomSheet -->
    <style name="BottomSheet_Timsanbong" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.BottomSheet.Timsanbong</item>
    </style>
    <style name="Widget.BottomSheet.Timsanbong" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.BottomSheet.Timsanbong</item>
        <item name="android:background">@color/background_primary</item>
    </style>
    <style name="ShapeAppearance.BottomSheet.Timsanbong" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_card</item>
        <item name="cornerSizeTopRight">@dimen/radius_card</item>
    </style>

    <style name="Theme.TimSanBong.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.TimSanBong.NoActionBar</item>
    </style>
</resources>
